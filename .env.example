# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=flashsale_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=flashsale

# NATS (leave empty for no auth in local dev)
NATS_USER=
NATS_PASS=

# Redis (leave empty for no auth in local dev)
REDIS_PASSWORD=

# Log level: debug | info | warning | error
LOG_LEVEL=info

# Sale parameters (frozen at T-30, NOT runtime-mutable)
MAX_PER_USER=2

# Gateway rate limit (per user, per endpoint)
BUY_WINDOW_SECONDS=10
BUY_WINDOW_MAX=1
MAX_INFLIGHT_BUY=5000
ADMIT_RATE=500

# OpenTelemetry — the OTel Collector OTLP gRPC endpoint. If unreachable, all
# services degrade gracefully (spans buffered/dropped; orders never affected).
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
SERVICE_VERSION=1.0.0
